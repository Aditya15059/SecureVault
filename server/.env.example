# ═══════════════════════════════════════════════════════════
# SecureVault Server — Environment Variables
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════

# ─── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CORS_ORIGIN=https://aditya15059.github.io

# ─── MongoDB ──────────────────────────────────────────────
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/securevault

# ─── JWT Auth ─────────────────────────────────────────────
JWT_SECRET=your-256-bit-secret-change-this-in-production
JWT_EXPIRES_IN=7d

# ─── n8n Webhook URLs ────────────────────────────────────
# Main event webhook (used by most workflows)
N8N_EVENT_WEBHOOK=https://your-n8n.com/webhook/securevault/events

# Dedicated webhooks per workflow
N8N_REGISTER_WEBHOOK=https://your-n8n.com/webhook/securevault/register
N8N_OTP_WEBHOOK=https://your-n8n.com/webhook/securevault/send-otp
N8N_ALERTS_WEBHOOK=https://your-n8n.com/webhook/securevault/security-alert

# n8n API key (must match SV_API_KEY in n8n environment)
N8N_API_KEY=your-n8n-api-key-here

# ─── AWS RDS (used by n8n, not directly by Express) ──────
RDS_HOST=securevault.xxxxxxx.rds.amazonaws.com
RDS_PORT=5432
RDS_DB=securevault_db
RDS_USER=n8n_writer
RDS_PASS=your_secure_rds_password

# ─── Admin Notifications ─────────────────────────────────
ADMIN_EMAIL=admin@securevault.io
ADMIN_TELEGRAM_CHAT_ID=your_telegram_chat_id
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# ─── Gmail (OAuth2 — configured in n8n credentials) ──────
GMAIL_USER=noreply@securevault.io
GMAIL_OAUTH_CLIENT_ID=xxx.apps.googleusercontent.com
GMAIL_OAUTH_CLIENT_SECRET=xxx
GMAIL_OAUTH_REFRESH_TOKEN=xxx
